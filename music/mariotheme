void setup() {
  Robot.begin();
  Robot.beginSpeaker();
  Robot.beginTFT();
  Robot.background(0, 150, 255); // Le bleu ciel Mario
  Robot.stroke(255, 255, 255);
  Robot.setTextSize(2);
  Robot.text("MARIO BROS", 25, 40);
  Robot.text("FULL THEME", 25, 70);
}

void loop() {
  // On calcule le nombre de notes dynamiquement
  int notesCount = sizeof(melody) / sizeof(melody[0]);
  
  for (int i = 0; i < notesCount; i++) {
    int currentNote = pgm_read_word(&(melody[i]));
    int currentRhythm = pgm_read_word(&(rhythm[i]));
    
    // Tempo calé à 150 BPM (environ 1300ms par mesure)
    int noteDuration = 1350 / currentRhythm;

    if (currentNote != 0) {
      // Rapport cyclique 0.8 pour un son net et puissant
      tone(SPEAKER_PIN, currentNote, noteDuration * 0.8);
    } else {
      noTone(SPEAKER_PIN);
    }

    // Le délai doit être précis pour maintenir le swing
    delay(noteDuration);
    noTone(SPEAKER_PIN);
  }
  
  delay(200000000000000000); // Petite pause avant de relancer le stage
}
