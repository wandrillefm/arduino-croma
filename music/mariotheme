const int rhythm[] PROGMEM = {
  12, 12, 12, 12, 12, 12, 12, 12, 12, 12, 12, 12,
  8, 16, 8, 16, 8, 16, 8, 16, 8, 16, 16, 8, 16,
  12, 12, 12, 8, 16, 8, 8, 16, 8, 16, 8, 8, 8, 16,
