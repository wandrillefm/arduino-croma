#include <ArduinoRobot.h>
#include <Wire.h>

void setup() {
  Robot.begin();
  Robot.beginSpeaker();
}

void loop() {
  playJingleBells();
  delay(3000);
}

void playJingleBells() {
  char jingle[] = 
    "4e 4e 4e 4- "
    "4e 4e 4e 4- "
    "4e 4g 4C 4d 4e 4f 4f 2- "
    "4f 4f 4f 4f 4f 4e 4e 4e 4e 4d 4d 4e 2- "
    "4g 4- 4e 4e 4e 4- "
    "4e 4e 4e 4- "
    "4e 4g 4C 4d 4e 4f 4f 4f 4f 4f 2e";
  Robot.playMelody(jingle);
}
