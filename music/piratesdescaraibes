const int rhythm[] PROGMEM = {
  16, 16, 8, 8, 16, 16, 8, 8, 16, 16, 8, 8, 16, 16, 16, 4,
  16, 16, 8, 8, 16, 16, 8, 8, 16, 16, 8, 8, 16, 16, 16, 4,
