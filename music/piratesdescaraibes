  NOTE_D5, NOTE_E5, NOTE_F5, NOTE_F5, NOTE_G5, NOTE_A5, NOTE_D5, 0, NOTE_D5, NOTE_F5, NOTE_E5, NOTE_E5, NOTE_F5, NOTE_D5, NOTE_D5, 0
