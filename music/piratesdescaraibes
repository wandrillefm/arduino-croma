void setup() {
  Robot.begin();
  Robot.beginSpeaker();
  Robot.beginTFT();
  Robot.background(0,0,0);
  Robot.stroke(255,255,255);
  Robot.text("MEM OPTIMIZED", 10, 50);
}

void loop() {
  for (int i = 0; i < 128; i++) {
    // Lecture spéciale depuis la mémoire Flash (pgm_read_word)
    int currentNote = pgm_read_word(&(melody[i]));
    int currentRhythm = pgm_read_word(&(rhythm[i]));

    if (currentNote == 0) {
      noTone(SPEAKER_PIN);
      delay(150);
      continue;
    }

    int tempoGeneral = 1300;
    int noteDuration = tempoGeneral / currentRhythm;

    int playTime = noteDuration;
    if (currentRhythm <= 4) playTime = noteDuration * 0.75; 
    
    tone(SPEAKER_PIN, currentNote, playTime);
    delay(noteDuration * 1.25);
    noTone(SPEAKER_PIN);
  }
  delay(5000);
}
